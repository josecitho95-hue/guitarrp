{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Audio2Tab",
  "version": "0.1.0",
  "identifier": "com.audio2tab.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "title": "Audio2Tab",
        "width": 760,
        "height": 760,
        "minWidth": 560,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../.venv/**/*",
      "../sidecar/**/*",
      "../.mt3_checkpoints/**/*"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
